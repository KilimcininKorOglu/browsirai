    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "1.3.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "picocolors": "1.1.1",
    "ws": "8.20.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.15.0",
    "@types/ws": "8.18.1",
    "jest-extended": "7.0.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "browser",
    "webdriver-bidi",
    "firefox",
    "mcp",
