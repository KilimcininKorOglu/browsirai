{
  "name": "foxbrowser",
  "version": "1.1.0",
  "description": "Live browser plugin for AI coding agents. Connect to your running Firefox session via WebDriver BiDi.",
  "author": "KilimcininKorOglu",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/KilimcininKorOglu/foxbrowser#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KilimcininKorOglu/foxbrowser.git"
  },
  "bugs": {
    "url": "https://github.com/KilimcininKorOglu/foxbrowser/issues"
  },
  "type": "module",
  "bin": {
    "foxbrowser": "./dist/bin.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
